# MongoDB Connection - Pilih salah satu format:
# Option 1: Localhost (gunakan ini untuk development lokal)
MONGODB_URI=

# Option 2: MongoDB Atlas (gunakan ini untuk production/cloud)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/eliasdex?retryWrites=true&w=majority

# Anime API
NEXT_PUBLIC_API_BASE_URL=https://api.jikan.moe/v4

# JWT Secret (generate a random string for production)
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production

# Next.js Metadata Base URL
NEXT_PUBLIC_URL=http://localhost:3000

# Midtrans Configuration
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=your_client_key
MIDTRANS_SERVER_KEY=your_server_key
MIDTRANS_ENV=sandbox  # or production